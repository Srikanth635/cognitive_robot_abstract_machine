<mujoco model="nav_world">

    <compiler angle="radian"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
        <rgba haze="0.1 0.15 0.2 1"/>
        <global azimuth="150" elevation="-25"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.4 0.55 0.7" rgb2="0.05 0.05 0.1"
                 width="512" height="512"/>
        <texture name="texfloor" type="2d" builtin="checker"
                 rgb1="0.28 0.32 0.36" rgb2="0.18 0.20 0.24"
                 width="512" height="512" mark="cross" markrgb="0.6 0.6 0.6"/>
        <material name="matfloor" texture="texfloor" texrepeat="6 6" reflectance="0.15"/>
    </asset>

    <worldbody>
        <!-- Lighting -->
        <light name="sun"  pos="0 0 5"   dir="0 0 -1"      directional="true"
               diffuse="0.7 0.7 0.7" specular="0.2 0.2 0.2" castshadow="true"/>
        <light name="fill" pos="-3 -3 4" dir="1 1 -1"      directional="true"
               diffuse="0.3 0.3 0.35" specular="0 0 0"/>

        <!-- Floor -->
        <geom name="floor" type="plane" size="6 6 0.1" material="matfloor"
              condim="3" friction="0.8 0.005 0.0001"/>

        <!-- ── Robot ───────────────────────────────────────────────────────── -->
        <!-- Body   : blue cylinder (r=0.18 m, h=0.14 m)                       -->
        <!-- Heading: yellow rectangular bump on the front face                 -->
        <!-- The freejoint lets set_body_position / set_body_quaternion work.   -->
        <body name="robot" pos="0 0 0.07">
            <freejoint name="robot_freejoint"/>
            <!-- Main chassis -->
            <geom name="chassis" type="cylinder" size="0.18 0.065"
                  rgba="0.18 0.48 0.85 1" condim="3" mass="5"/>
            <!-- Direction indicator (yellow wedge on front) -->
            <geom name="front_marker" type="box" size="0.05 0.025 0.03"
                  pos="0.17 0 0.04" rgba="1.0 0.85 0.1 1" mass="0.01"/>
            <!-- Two side "wheels" (visual only) -->
            <geom name="wheel_l" type="cylinder" size="0.07 0.02"
                  pos="0 0.19 0" quat="0.7071 0.7071 0 0"
                  rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>
            <geom name="wheel_r" type="cylinder" size="0.07 0.02"
                  pos="0 -0.19 0" quat="0.7071 0.7071 0 0"
                  rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>
        </body>

        <!-- ── Goal marker ────────────────────────────────────────────────── -->
        <!-- Green flag at (2.5, 1.8) — robot should navigate here.           -->
        <body name="goal" pos="2.5 1.8 0">
            <geom type="box"      size="0.18 0.18 0.03" pos="0 0 0.03"
                  rgba="0.2 0.85 0.35 0.5"/>
            <geom type="cylinder" size="0.025 0.45"     pos="0 0 0.47"
                  rgba="0.6 0.6 0.6 1"/>
            <geom type="box"      size="0.18 0.03 0.10" pos="0.18 0 0.95"
                  rgba="0.2 0.85 0.35 1"/>
        </body>

        <!-- ── Static obstacles ───────────────────────────────────────────── -->
        <!-- Orange/red boxes — the robot must navigate around these.          -->
        <body name="wall_a" pos="1.0  0.4  0">
            <geom type="box" size="0.12 0.55 0.22" rgba="0.82 0.32 0.18 1"
                  condim="3"/>
        </body>
        <body name="wall_b" pos="0.3 -0.9  0">
            <geom type="box" size="0.55 0.12 0.22" rgba="0.82 0.32 0.18 1"
                  condim="3"/>
        </body>
        <body name="pillar" pos="1.7 -0.5  0">
            <geom type="cylinder" size="0.15 0.30" rgba="0.65 0.38 0.18 1"
                  condim="3"/>
        </body>
        <body name="block"  pos="-0.8 1.3  0">
            <geom type="box" size="0.20 0.20 0.18" rgba="0.82 0.32 0.18 1"
                  condim="3"/>
        </body>

        <!-- ── Boundary walls (keep the robot on screen) ─────────────────── -->
        <body name="border_n" pos="0  5 0">
            <geom type="box" size="6 0.1 0.3" rgba="0.35 0.35 0.4 1"/>
        </body>
        <body name="border_s" pos="0 -5 0">
            <geom type="box" size="6 0.1 0.3" rgba="0.35 0.35 0.4 1"/>
        </body>
        <body name="border_e" pos=" 5 0 0">
            <geom type="box" size="0.1 6 0.3" rgba="0.35 0.35 0.4 1"/>
        </body>
        <body name="border_w" pos="-5 0 0">
            <geom type="box" size="0.1 6 0.3" rgba="0.35 0.35 0.4 1"/>
        </body>

    </worldbody>

</mujoco>
